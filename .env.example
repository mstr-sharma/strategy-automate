# Strategy automation — environment configuration template.
# Copy to `.env` and fill in for your tenant. Never commit the populated file.
#
#   cp .env.example .env
#   set -a; source .env; set +a
#
# All scripts and skills in this repo read these values from env vars. Every
# CLI flag (`--base`, `--user`, `--password`, `--project-id`, `--dest-folder`)
# still overrides the env var when set explicitly.

# ── Required ──────────────────────────────────────────────────────────────────

# Library base URL. Example: https://yourtenant.customer.cloud.microstrategy.com/MicroStrategyLibrary
MSTR_BASE=

# Username for /api/auth/login
MSTR_USER=

# Password. Use a secret store / keychain in production; env var acceptable locally.
MSTR_PASSWORD=

# ── One of these is required ──────────────────────────────────────────────────

# Project UUID (32-hex). If set, used directly.
MSTR_PROJECT_ID=

# Project display name. If MSTR_PROJECT_ID is blank, helpers will resolve the
# project by name at login.
MSTR_PROJECT_NAME=

# ── Optional ──────────────────────────────────────────────────────────────────

# Login mode: 1 standard (default), 8 LDAP, 16 SAML, 4096 identity-token passthrough.
MSTR_LOGIN_MODE=1

# Destination folder for new Mosaic data models. Look up once via `/api/folders/…`
# in the target project; required by `build_mosaic.py build`.
MSTR_DEST_FOLDER_ID=

# Legacy alias for MSTR_DEST_FOLDER_ID, kept for back-compat;
# MSTR_DEST_FOLDER_ID wins when both are set.
#MSTR_DEST_FOLDER=

# Default password for `build_mosaic.py create-users` rows that omit one
# (read via --default-password-env, which defaults to this var name).
#MSTR_NEW_USER_PASSWORD=

# ── Optional: borrowed session (Studio Cloud / SSO tenants) ───────────────────
# When direct /api/auth/login isn't usable, copy these out of a logged-in
# browser via DevTools; build_mosaic.py reuses the session in place and skips
# /auth/login + /auth/logout so the human's UI session stays intact.

# REST session token (DevTools → Network → X-MSTR-AuthToken header).
#MSTR_AUTH_TOKEN=

# Modeling Service identity token; optional — minted from the borrowed session
# when omitted and a Modeling-Service-bound command runs.
#MSTR_IDENTITY_TOKEN=

# JSESSIONID cookie from the logged-in browser session.
#MSTR_SESSION_COOKIE=

# library-ingress cookie (Strategy Cloud load-balancer routing cookie).
#MSTR_INGRESS_COOKIE=

# ── Optional: strategy_validate.py subject-matter overrides ───────────────────
# Defaults target the MicroStrategy Tutorial project so the live-tenant
# validator works there out-of-the-box; override to point at any project.

# Attribute to resolve/inspect in workflows 2–3 and 9 (default: Category).
#MSTR_VALIDATE_ATTR=

# Element of that attribute for the security-filter qualification (default: Books).
#MSTR_VALIDATE_ELEMENT=

# Comma-separated metric names for definition inspection (default: Revenue,Profit,Cost).
#MSTR_VALIDATE_METRICS=

# Comma-separated terms for the report/cube search workflow
# (default: Revenue,Sales,Category,Profit,Inventory).
#MSTR_VALIDATE_SEARCH_TERMS=

# Comma-separated terms for the document/dashboard export probe
# (default: Tutorial Home,Dashboard,Sales,Revenue).
#MSTR_VALIDATE_DASHBOARD_TERMS=

# Name for the validation security filter
# (default: "<attr> in <element> — secFilter_validation").
#MSTR_VALIDATE_SF_NAME=

# ── Notes ─────────────────────────────────────────────────────────────────────
#
# - MCP connectivity (for `get_projects`, `get_mosaic_models`, `get_semantics`,
#   `query`) is configured OUTSIDE this repo, through your AI tool's MCP connector
#   settings (Claude Code, Codex CLI, Cursor, Gemini CLI, etc.). The skills here
#   reference MCP tools by name, not by server ID.
#
# - Some workstations (notably ones with an Anaconda Python whose OpenSSL lags
#   the tenant's TLS stack) need `/usr/bin/python3` for REST calls. If you see
#   SSL handshake timeouts, switch interpreters before debugging the script.
