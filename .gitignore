.DS_Store
*.pyc
__pycache__/

# Local assistant/runtime state
.claude/

# Optional generated API cache; refresh with:
# python3 skills/build-mosaic-model/scripts/build_mosaic.py openapi-summary --out openapi.yaml
/openapi.yaml
/openapi.yml
/openapi.json

# Local secrets and transient logs
.env
.env.*
!.env.example
*.log

# Operator-local credential notes (never commit)
ignore/

# captures/ READMEs (dated transcripts) are tracked institutional memory;
# raw tenant payloads and run scripts dumped next to them stay local
# (scripts embed tenant object IDs; generalized versions belong under skills/)
captures/**/*.json
captures/**/*.ndjson
captures/**/*.har
captures/**/*.csv
captures/**/*.parquet
captures/**/*.py
