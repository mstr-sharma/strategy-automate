.DS_Store
*.pyc
__pycache__/

# Local assistant/runtime state
.claude/

# Optional generated API cache; refresh with:
# python3 skill/scripts/build_mosaic.py openapi-summary --out openapi.yaml
/openapi.yaml
/openapi.yml
/openapi.json

# Local secrets and transient logs
.env
.env.*
!.env.example
*.log

# captures/ READMEs (dated transcripts) are tracked institutional memory;
# raw tenant payloads dumped next to them stay local
captures/**/*.json
captures/**/*.ndjson
captures/**/*.har
captures/**/*.csv
captures/**/*.parquet
